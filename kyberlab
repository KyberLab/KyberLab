Options:
  -i IMAGE    Image name (e.g. BusyBox, Linux, BuildRoot, ...)
  -d NAME     Docker name (e.g. develop, qemu, virt-aarch64, ...)
"""

UNKNOWN_HELP = """KyberLab CLI - Embedded Systems Development Platform

Error: Not in a KyberLab repo root or workspace directory.

Usage:
  kyberlab help                     Show this help message
  kyberlab init [options]           Initialize a new workspace (in repo root)

  After initializing a workspace, cd into build/<BOARD>/ and use:
    kyberlab build [-i IMAGE]       Build an image
    kyberlab dkbuild [-d NAME]      Build Docker workbench image
    ... see 'kyberlab help' from a workspace for full command list

Init Options:
  -u, --url     Git URL          (default: https://github.com/KyberLab/KyberLab.git)
  -b, --branch  Branch           (default: master)
  -d, --board   Board name       (default: virt-aarch64)
  -m, --config  Config file name (default: default)
"""


def cmd_help(context):
    if context == CONTEXT_REPO:
        print(REPO_HELP, end="")
    elif context == CONTEXT_WORKSPACE:
        print(WORKSPACE_HELP, end="")
    else:
        print(UNKNOWN_HELP, end="")


# --- Main ---

def build_parser():
    parser = argparse.ArgumentParser(
        prog="kyberlab",
        description="KyberLab CLI",
        add_help=False,
    )
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("help", help="Show context-appropriate help")

    p_init = sub.add_parser("init", help="Initialize a new workspace")
    p_init.add_argument("-u", "--url",    default="https://github.com/KyberLab/KyberLab.git")
    p_init.add_argument("-b", "--branch", default="master")
    p_init.add_argument("-d", "--board",  default="virt-aarch64")
    p_init.add_argument("-m", "--config", default="default")

    for phase in BUILD_PHASES:
        p = sub.add_parser(phase, help=f"Run 'make {phase}' (or '<IMAGE>_{phase}')")
        p.add_argument("-i", "--image", default=None, help="Target image name")

    for action in DOCKER_COMMANDS:
        p = sub.add_parser(action, help=f"Docker: {action}")
        p.add_argument("-d", "--name", default=None, help="Docker name")

    return parser


def main():
    context, root = detect_context()
    parser = build_parser()
    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(1)

    if args.command == "help":
        cmd_help(context)

    elif args.command == "init":
        require_repo_root(context)
        do_init(args, root)

    elif args.command in BUILD_PHASES:
        # Auto-detect image from cwd if -i not given
        image = args.image or detect_image_from_cwd(root)
        do_build_phase(args.command, image, context, root)

    elif args.command in DOCKER_COMMANDS:
        # Auto-detect docker name from cwd if -d not given
        name = args.name or detect_docker_from_cwd(root)
        if not name:
            # Fallback to board name from workspace path
            parent = os.path.dirname(root)
            if os.path.basename(parent) == "build":
                name = os.path.basename(root)
            else:
                name = "virt-aarch64"
        do_docker_command(args.command, name, context, root)

    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
