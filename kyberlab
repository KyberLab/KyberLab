#!/usr/bin/env python3
"""
KyberLab CLI - Embedded Systems Development Platform

Unified CLI that auto-detects whether it's running from:
  - Repo root: the KyberLab manifests/templates git repository
  - Workspace: an initialized workspace (contains WorkSpace.mk)
  - Workspace subdirectory: nested paths inside a workspace

In repo root: supports 'init' to create workspaces.
In workspace:  supports build phases and docker container commands.

Run with: python3 kyberlab <command> [options]
"""

import argparse
import os
import shutil
import subprocess
import sys

REQUIRED_TOOLS = ("git", "repo", "make", "docker")

BUILD_PHASES = ("build", "fetch", "patch", "config", "install",
                "package", "clean", "distclean", "emu")

DOCKER_COMMANDS = ("dkbuild", "dkrun", "dkrund", "dkexec", "dkpin")

DOCKER_MAKE_PREFIX = {
    "dkbuild": "build",
    "dkrun":   "run",
    "dkrund":  "rund",
    "dkexec":  "exec",
    "dkpin":   "dockpin",
}

# --- Context detection ---

CONTEXT_UNKNOWN  = "UNKNOWN"
CONTEXT_REPO     = "REPO_ROOT"
CONTEXT_WORKSPACE = "WORKSPACE"


def detect_context(cwd=None):
    """Walk up from cwd checking for KyberLab context.

    Returns (context_type, root_path) where:
      - CONTEXT_REPO:      root = git repo with manifests/ + template/
      - CONTEXT_WORKSPACE: root = dir containing WorkSpace.mk
      - CONTEXT_UNKNOWN:   root = cwd
    """
    path = os.path.abspath(cwd or os.getcwd())
    while True:
        if os.path.isfile(os.path.join(path, "WorkSpace.mk")):
            return CONTEXT_WORKSPACE, path
        if (os.path.isdir(os.path.join(path, "manifests"))
                and os.path.isdir(os.path.join(path, "template"))):
            return CONTEXT_REPO, path
        parent = os.path.dirname(path)
        if parent == path:
            break
        path = parent
    return CONTEXT_UNKNOWN, os.path.abspath(cwd or os.getcwd())


def detect_image_from_cwd(workspace_root, cwd=None):
    """Walk up from cwd to workspace_root, check if we're inside an IMAGE directory.

    Checks each directory name against known images from two sources:
      1. config/image/<IMAGE>/  (image definitions)
      2. build/<IMAGE>/          (build output directories)
    Returns the image name or None.
    """
    cwd_path = os.path.abspath(cwd or os.getcwd())

    # Collect known image names from config/image/
    known = {}
    image_dir = os.path.join(workspace_root, "config", "image")
    if os.path.isdir(image_dir):
        for d in os.listdir(image_dir):
            if os.path.isdir(os.path.join(image_dir, d)):
                known[d.lower()] = d

    # Collect known image names from build/ (output directories)
    build_dir = os.path.join(workspace_root, "build")
    if os.path.isdir(build_dir):
        for d in os.listdir(build_dir):
            if os.path.isdir(os.path.join(build_dir, d)):
                known.setdefault(d.lower(), d)

    # Walk up from cwd to workspace_root
    path = cwd_path
    while True:
        lower = os.path.basename(path).lower()
        if lower in known:
            return known[lower]
        if path == workspace_root:
            break
        parent = os.path.dirname(path)
        if parent == path:
            break
        path = parent
    return None


def detect_docker_from_cwd(workspace_root, cwd=None):
    """Walk up from cwd to workspace_root, check if we're inside a docker directory.

    Checks each directory name against known docker names in bench/image/dockerfile/.
    Returns the docker name or None.
    """
    cwd_path = os.path.abspath(cwd or os.getcwd())
    docker_dir = os.path.join(workspace_root, "bench", "image", "dockerfile")

    if not os.path.isdir(docker_dir):
        return None
    known = {d.lower(): d for d in os.listdir(docker_dir)
             if os.path.isdir(os.path.join(docker_dir, d))}

    path = cwd_path
    while True:
        lower = os.path.basename(path).lower()
        if lower in known:
            return known[lower]
        if path == workspace_root:
            break
        parent = os.path.dirname(path)
        if parent == path:
            break
        path = parent
    return None


def detect_plat_from_workspace(work_dir):
    """Detect platform from workspace's .repo/manifests directory.

    Returns the platform name (e.g., 'qemu', 'virt') or None if not found.
    """
    manifests_path = os.path.join(work_dir, ".repo", "manifests", "manifests")
    if not os.path.isdir(manifests_path):
        return None
    for plat in os.listdir(manifests_path):
        plat_path = os.path.join(manifests_path, plat)
        if os.path.isdir(plat_path):
            return plat
    return None


def ensure_kyberemu(work_dir):
    """Ensure KyberEmu repository is available; install if missing."""
    kyberemu_dir = os.path.join(work_dir, "build", "KyberEmu")
    if not os.path.isdir(kyberemu_dir):
        print("[kyberlab] KyberEmu not found. Initializing...")
        run_make("kyberemu_install", work_dir)


# --- Make runner ---

def run_make(target, work_dir):
    """Run make <target> from work_dir. Exit on failure."""
    print(f"[kyberlab] Running 'make {target}' from {work_dir}")
    ret = subprocess.call(["make", target], cwd=work_dir)
    if ret != 0:
        print(f"Error: 'make {target}' failed (exit {ret})")
        sys.exit(ret)


def run_make_with_env(env_vars, target, work_dir):
    """Run make <target> from work_dir with extra make variables."""
    cmd = ["make", f"{env_vars}", target]
    print(f"[kyberlab] Running 'make {env_vars} {target}' from {work_dir}")
    ret = subprocess.call(cmd, cwd=work_dir)
    if ret != 0:
        print(f"Error: 'make {target}' failed (exit {ret})")
        sys.exit(ret)


def is_container_running(name, work_dir):
    """Check if a container for NAME is running under the current workspace.

    Container naming: bench_daemon_name in the Makefile uses
    $(BENCH_NAME)_<IMAGE>_<user>_<md5prefix> pattern.
    We check by matching the bench name prefix in `docker ps`.
    """
    try:
        result = subprocess.run(
            ["docker", "ps", "--format", "{{.Names}}"],
            capture_output=True, text=True, cwd=work_dir
        )
        container_names = result.stdout.strip().splitlines()
        # Container name format: $(BENCH_NAME)_<IMAGE>_<user>_<md5>
        # BENCH_NAME defaults to "bench", so pattern is "bench_<IMAGE>_..."
        for cn in container_names:
            if f"_{name}_" in cn:
                return True
        return False
    except (subprocess.SubprocessError, FileNotFoundError):
        return False


def require_workspace(context):
    if context != CONTEXT_WORKSPACE:
        print("Error: This command requires an initialized workspace.")
        print("       Use 'kyberlab init' from the KyberLab repo root first.")
        sys.exit(1)


def require_repo_root(context):
    if context != CONTEXT_REPO:
        print("Error: 'init' must be run from the KyberLab repo root.")
        sys.exit(1)


# --- Init command ---

def check_dependencies():
    missing = [t for t in REQUIRED_TOOLS if shutil.which(t) is None]
    if not missing:
        return
    print(f"Error: The following required tools are not installed: {', '.join(missing)}")
    print("Please install them before running 'kyberlab init'.")
    print()
    tips = {
        "git":    "git:     sudo apt install git",
        "repo":   "repo:    pip install git-repo  (or https://gerrit.googlesource.com/git-repo)",
        "make":   "make:    sudo apt install make",
        "docker": "docker:  https://docs.docker.com/engine/install/",
    }
    for t in missing:
        print(f"  {tips.get(t, f'{t}:    please install {t}')}")
    sys.exit(1)


def detect_plat(board, repo_root):
    manifests_dir = os.path.join(repo_root, "manifests")
    for name in sorted(os.listdir(manifests_dir)):
        if os.path.isdir(os.path.join(manifests_dir, name, board)):
            return name
    print(f"Error: board '{board}' not found in manifests/")
    sys.exit(1)


def do_init(args, base_dir, context, platform=None):
    check_dependencies()

    url = args.url
    branch = args.branch
    board = args.board
    config = args.config

    # Determine platform and manifest path based on context
    if context == CONTEXT_REPO:
        # Auto-detect platform from local manifests
        plat = detect_plat(board, base_dir)
        manifest = f"manifests/{plat}/{board}/{config}.xml"
        manifest_abs = os.path.join(base_dir, manifest)
        if not os.path.isfile(manifest_abs):
            print(f"Error: manifest '{manifest}' not found in repository")
            sys.exit(1)
    elif context == CONTEXT_UNKNOWN:
        # Require platform argument when outside repo
        if not platform:
            print("Error: When initializing from outside the KyberLab repository, the -p/--platform flag is required.")
            print("Usage: kyberlab init -d <board> -p <platform> [-u <url>] [-b <branch>] [-m <config>]")
            sys.exit(1)
        plat = platform
        manifest = f"manifests/{plat}/{board}/{config}.xml"
        # No local file check; repo will fetch from URL
    else:
        # Should not happen, but be safe
        print(f"Error: Unexpected context '{context}' for init")
        sys.exit(1)

    workspace = os.path.join(base_dir, args.board)
    os.makedirs(workspace, exist_ok=True)

    print(f"[kyberlab] Initializing workspace '{board}'...")
    print(f"  URL:        {url}")
    print(f"  Branch:     {branch}")
    print(f"  Manifest:   {manifest}")
    print(f"  Workspace:  {workspace}")
    print()

    nproc = os.cpu_count() or 4
    subprocess.check_call(["repo", "init", "-u", url, "-b", branch, "-m", manifest],
                          cwd=workspace)
    subprocess.check_call(["repo", "sync", "-j", str(nproc), "-v"], cwd=workspace)
    subprocess.check_call(
        ["repo", "forall", "-c",
         "if [ -f .gitmodules ]; then git fetch && "
         "git submodule update --init --recursive --force; fi"],
        cwd=workspace)

    tpl = os.path.join(workspace, ".repo", "manifests", "template")
    if os.path.isdir(tpl):
        for f in os.listdir(tpl):
            src = os.path.join(tpl, f)
            if os.path.isfile(src):
                shutil.copy2(src, workspace)
        print("[kyberlab] Template files copied.")
    else:
        print(f"[kyberlab] Warning: '{tpl}' not found")

    rel = os.path.relpath(workspace, base_dir)
    print()
    print(f"[kyberlab] Workspace '{board}' initialized successfully!")
    print(f"[kyberlab] Enter with: cd {rel}")


# --- Build phase commands ---

def do_build_phase(phase, image, context, work_dir):
    require_workspace(context)

    if image:
        target = f"{image}_{phase}"
    else:
        target = phase

    run_make(target, work_dir)


# --- Docker commands ---

def do_docker_command(action, name, context, work_dir, user_cmd=None):
    """Run a docker-related make target.

    For 'dkexec': checks container is running first, passes USER_RUN_CMD if given.
    """
    require_workspace(context)

    # dkexec requires container running check
    if action == "dkexec":
        if not is_container_running(name, work_dir):
            print(f"Error: Container '{name}' is not running.")
            print(f"       Start it first with: kyberlab dkrund -d {name}")
            sys.exit(1)
        prefix = DOCKER_MAKE_PREFIX[action]
        target = f"{prefix}_{name}"
        if user_cmd:
            run_make_with_env(f"USER_RUN_CMD={user_cmd}", target, work_dir)
        else:
            run_make(target, work_dir)
        return

    # Other docker commands: normal make invocation
    prefix = DOCKER_MAKE_PREFIX[action]
    target = f"{prefix}_{name}"
    run_make(target, work_dir)


# --- Emu command ---

def do_emu(image, context, work_dir):
    """Run the emu command with platform check and KyberEmu auto-install."""
    require_workspace(context)

    # Determine make target
    target = f"{image}_emu" if image else "emu"

    # Check platform restriction: only qemu supported
    plat = detect_plat_from_workspace(work_dir)
    if plat != "qemu":
        print("Error: 'emu' command only supports qemu platform.")
        sys.exit(1)

    # Ensure KyberEmu is available
    ensure_kyberemu(work_dir)

    # Run the emu make target
    run_make(target, work_dir)


# --- Help ---

